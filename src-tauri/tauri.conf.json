{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ease-Island",
  "version": "0.2.2",
  "identifier": "com.cc-island.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png"
    },
    "windows": [
      {
        "label": "main",
        "title": "CC-Island",
        "width": 300,
        "height": 38,
        "minWidth": 300,
        "minHeight": 38,
        "maxWidth": 600,
        "maxHeight": 750,
        "resizable": false,
        "fullscreen": false,
        "focus": false,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": true,
        "skipTaskbar": true,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}