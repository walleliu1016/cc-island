{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CC-Island",
  "version": "0.1.0",
  "identifier": "com.cc-island.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CC-Island",
        "width": 420,
        "height": 500,
        "minWidth": 380,
        "minHeight": 44,
        "maxWidth": 550,
        "maxHeight": 700,
        "resizable": false,
        "fullscreen": false,
        "focus": false,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": true,
        "skipTaskbar": true,
        "center": false,
        "x": 0,
        "y": 5
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}